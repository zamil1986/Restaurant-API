generator client {
  provider = "prisma-client  "
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model food_data {
  id_food   Int     @id @default(autoincrement())
  food_name String? @db.VarChar(50)
  types     String? @db.VarChar(45)
  price     Int?
}

model member_data {
  member_id Int     @id @default(autoincrement())
  name      String? @db.VarChar(40)
  age       Int?
}
